{
  "name": "@envoice-backend/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "nx:reset": "nx reset",
    "nx:run-many": "nx run-many",
    "lint": "pnpm run nx:run-many --target=lint",
    "fix": "pnpm run nx:run-many --target=lint --fix",
    "nx:affected": "nx affected --parallel=2 --nxBail",
    "docker-build": "pnpm nx:run-many --target=docker-build --verbose",
    "docker:start:provider": "docker compose -f docker-compose.provider.yaml up -d",
    "docker:start:dev": "docker compose -f docker-compose.dev.yaml up -d",
    "docker:stop:dev": "docker compose -f docker-compose.dev.yaml down",
    "build": "pnpm nx:reset && pnpm nx:run-many -t build --no-cache && pnpm docker-build && pnpm docker:start:provider && pnpm docker:stop:dev && pnpm docker:start:dev",
    "dev": "pnpm nx:reset && pnpm nx:run-many -t serve",
    "dev-lite": "pnpm dev --projects=bff,authorizer,user-access,product,invoice",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.1.11",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "~6.19.2",
    "axios": "^1.6.0",
    "cloudinary": "^2.8.0",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "kafkajs": "^2.2.4",
    "nestjs-zod": "^5.1.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "uuid": "^13.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "22.0.2",
    "@nx/eslint-plugin": "22.0.2",
    "@nx/jest": "22.0.2",
    "@nx/js": "22.0.2",
    "@nx/nest": "22.0.2",
    "@nx/node": "22.0.2",
    "@nx/web": "22.0.2",
    "@nx/webpack": "22.0.2",
    "@nx/workspace": "22.0.2",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "20.19.9",
    "baseline-browser-mapping": "^2.9.12",
    "dotenv": "^17.2.3",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "lint-staged": "^16.2.6",
    "nx": "22.0.2",
    "prettier": "^2.6.2",
    "prisma": "~6.19.2",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "webpack-cli": "^5.1.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml,html}": [
      "prettier --write"
    ]
  }
}
